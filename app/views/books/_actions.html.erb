<%= link_to "詳細", book_path(book), class: "btn btn-xs btn-outline" %>
<% if admin? %>
  <%= link_to "編集", edit_book_path(book), class: "btn btn-xs btn-outline" %>
  <%= button_to "削除", book_path(book), method: :delete,
        class: "btn btn-xs btn-error btn-outline",
        form: { data: { turbo_confirm: "「#{book.title}」を削除します。よろしいですか？" } } %>
<% end %>
