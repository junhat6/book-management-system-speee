<%= form_with(model: @book, local: true, class: "space-y-4") do |form| %>
  <% if @book.errors.any? %>
    <div role="alert" class="alert alert-error">
      <div>
        <h2 class="font-bold"><%= pluralize(@book.errors.count, "件") %>のエラーで保存できませんでした</h2>
        <ul class="list-disc list-inside text-sm">
          <% @book.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    </div>
  <% end %>

  <% if @book.cover_image.attached? %>
    <div>
      <%= image_tag @book.cover_image, class: "w-24 h-32 object-cover rounded shadow" %>
    </div>
  <% elsif @book.remote_cover_image_url.present? %>
    <div>
      <%= image_tag @book.remote_cover_image_url, class: "w-24 h-32 object-cover rounded shadow" %>
      <p class="text-xs text-base-content/50 mt-1">登録すると表紙画像として保存されます</p>
    </div>
  <% end %>
  <%= form.hidden_field :remote_cover_image_url %>

  <div>
    <%= form.label :title, "タイトル", class: "label" %>
    <%= form.text_field :title, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= form.label :isbn, "ISBN", class: "label" %>
    <%= form.text_field :isbn, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= form.label :published_year, "出版年", class: "label" %>
    <%= form.number_field :published_year, class: "input input-bordered w-full" %>
  </div>

  <div>
    <%= form.label :publisher, "出版社", class: "label" %>
    <%= form.text_field :publisher, class: "input input-bordered w-full" %>
  </div>

  <%= render "checkbox_chip_field", form: form, method: :author_ids, collection: @authors,
        label_text: "著者（既存）", filter_placeholder: "著者名で絞り込み",
        empty_message: "既存著者がまだありません。下の入力欄から新しい著者を追加できます。" %>

  <div>
    <%= form.label :new_author_names, "新しい著者を追加", class: "label" %>
    <%= form.text_field :new_author_names, class: "input input-bordered w-full", placeholder: "例: 夏目漱石、太宰治（「、」区切りで複数追加）" %>
  </div>

  <%= render "checkbox_chip_field", form: form, method: :tag_ids, collection: @tags,
        label_text: "タグ・ジャンル（既存）", filter_placeholder: "タグ名で絞り込み",
        empty_message: "既存タグがまだありません。下の入力欄から新しいタグを追加できます。" %>

  <div>
    <%= form.label :new_tag_names, "新しいタグを追加", class: "label" %>
    <%= form.text_field :new_tag_names, class: "input input-bordered w-full", placeholder: "例: 技術書、Ruby（「、」区切りで複数登録）" %>
  </div>

  <% if @book.new_record? %>
    <div>
      <%= form.label :initial_stock_count, "冊数（在庫）", class: "label" %>
      <%= form.number_field :initial_stock_count, value: @book.initial_stock_count || 1, min: 1,
            class: "input input-bordered w-full" %>
      <p class="text-sm text-base-content/60">登録後は書籍詳細ページから在庫を追加・削除できます。</p>
    </div>
  <% end %>

  <div class="flex justify-end gap-2 pt-2">
    <%= link_to "キャンセル", books_path, class: "btn btn-ghost" %>
    <%= form.submit submit_label, class: "btn btn-primary" %>
  </div>
<% end %>
