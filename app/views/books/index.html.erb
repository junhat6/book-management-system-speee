<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold">蔵書一覧</h1>
  <span class="badge badge-neutral"><%= @books.size %> 冊</span>
</div>

<%= form_with url: books_path, method: :get, class: "mb-6" do |form| %>
  <div class="join w-full max-w-md">
    <%= form.text_field :q, value: params[:q], placeholder: "タイトル・著者名で検索",
          class: "input input-bordered join-item w-full" %>
    <%= form.submit "検索", class: "btn btn-primary join-item" %>
  </div>
<% end %>

<% if @books.any? %>
  <div class="card bg-base-100 shadow-sm">
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>タイトル</th>
            <th>著者</th>
            <th>ISBN</th>
            <th>出版年</th>
            <th>出版社</th>
            <th class="text-right">操作</th>
          </tr>
        </thead>
        <tbody>
          <% @books.each do |book| %>
            <tr class="hover">
              <td class="font-medium">
                <%= link_to book.title, book_path(book), class: "link link-hover" %>
              </td>
              <td><%= book.authors.map(&:name).join("、") %></td>
              <td><%= book.isbn %></td>
              <td><%= book.published_year %></td>
              <td><%= book.publisher %></td>
              <td class="text-right">
                <div class="flex justify-end gap-1">
                  <%= link_to "詳細", book_path(book), class: "btn btn-xs btn-outline" %>
                  <%= link_to "編集", edit_book_path(book), class: "btn btn-xs btn-outline" %>
                  <%= button_to "削除", book_path(book), method: :delete,
                        class: "btn btn-xs btn-error btn-outline",
                        form: { data: { turbo_confirm: "「#{book.title}」を削除します。よろしいですか？" } } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
<% elsif params[:q].present? %>
  <div class="hero bg-base-100 rounded-box py-16">
    <div class="hero-content text-center">
      <p class="text-base-content/60">該当する本が見つかりませんでした。</p>
    </div>
  </div>
<% else %>
  <div class="hero bg-base-100 rounded-box py-16">
    <div class="hero-content text-center">
      <div>
        <p class="text-base-content/60 mb-4">本はまだ登録されていません。</p>
        <%= link_to "最初の本を登録する", new_book_path, class: "btn btn-primary" %>
      </div>
    </div>
  </div>
<% end %>
