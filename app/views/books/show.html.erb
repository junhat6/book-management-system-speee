<div class="max-w-2xl mx-auto">
  <div class="card bg-base-100 shadow-sm">
    <div class="card-body">
      <% if @book.cover_image.attached? %>
        <%= image_tag @book.cover_image, class: "w-32 h-44 object-cover rounded shadow mb-4" %>
      <% end %>

      <h1 class="card-title text-2xl mb-4"><%= @book.title %></h1>

      <dl class="grid grid-cols-3 gap-y-3 text-sm">
        <dt class="text-base-content/60">著者</dt>
        <dd class="col-span-2"><%= @book.authors.map(&:name).join("、") %></dd>

        <dt class="text-base-content/60">ISBN</dt>
        <dd class="col-span-2"><%= @book.isbn %></dd>

        <dt class="text-base-content/60">出版年</dt>
        <dd class="col-span-2"><%= @book.published_year %></dd>

        <dt class="text-base-content/60">出版社</dt>
        <dd class="col-span-2"><%= @book.publisher %></dd>

        <dt class="text-base-content/60">タグ</dt>
        <dd class="col-span-2">
          <% if @book.tags.any? %>
            <div class="flex flex-wrap gap-1">
              <% @book.tags.each do |tag| %>
                <%= link_to tag.name, books_path(tag_id: tag.id), class: "badge badge-outline badge-primary" %>
              <% end %>
            </div>
          <% else %>
            <span class="text-base-content/40">未設定</span>
          <% end %>
        </dd>

        <dt class="text-base-content/60">在庫</dt>
        <dd class="col-span-2">
          全 <%= @book.stock_count %> 冊中 <%= @book.available_stock_count %> 冊が貸出可能
        </dd>
      </dl>

      <div class="mt-4">
        <% if authenticated? && (my_rental = @book.active_rental_for(Current.user)) %>
          <span class="badge badge-warning">貸出中（あなた）</span>
          <%= button_to "返却する", rental_path(my_rental), method: :patch, class: "btn btn-warning" %>
        <% elsif @book.available_stock_count.zero? %>
          <span class="badge badge-error">在庫なし（全冊貸出中）</span>
        <% elsif authenticated? %>
          <%= button_to "借りる", book_rentals_path(@book), class: "btn btn-primary" %>
        <% else %>
          <%= link_to "ログインして借りる", new_session_path, class: "btn btn-primary" %>
        <% end %>
      </div>

      <% if admin? %>
        <div class="mt-6">
          <h2 class="font-bold mb-2">在庫管理</h2>
          <% if @book.items.any? %>
            <table class="table table-sm">
              <thead>
                <tr>
                  <th>管理番号</th>
                  <th>状態</th>
                  <th class="text-right">操作</th>
                </tr>
              </thead>
              <tbody>
                <% @book.items.each do |item| %>
                  <tr>
                    <td>#<%= item.id %></td>
                    <td>
                      <% if item.available? %>
                        <span class="badge badge-success">貸出可</span>
                      <% else %>
                        <span class="badge badge-error">貸出中</span>
                      <% end %>
                    </td>
                    <td class="text-right">
                      <%= button_to "削除", book_item_path(@book, item), method: :delete,
                            class: "btn btn-xs btn-error btn-outline",
                            form: { data: { turbo_confirm: "「#{@book.title}」の在庫 ##{item.id} を削除します。よろしいですか？" } } %>
                    </td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          <% else %>
            <p class="text-sm text-base-content/60">在庫がありません。</p>
          <% end %>
          <%= button_to "在庫を1冊追加", book_items_path(@book), class: "btn btn-sm btn-outline mt-2" %>
        </div>
      <% end %>

      <div class="card-actions justify-between mt-6">
        <%= link_to "一覧へ戻る", books_path, class: "btn btn-ghost" %>
        <% if admin? %>
          <div class="flex gap-2">
            <%= link_to "編集", edit_book_path(@book), class: "btn btn-outline" %>
            <%= button_to "削除", book_path(@book), method: :delete,
                  class: "btn btn-error btn-outline",
                  form: { data: { turbo_confirm: "「#{@book.title}」を削除します。よろしいですか？" } } %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
