<%# kaminari のビューは app/views/kaminari/ に置くとデフォルトより優先される %>
<%= paginator.render do -%>
  <nav class="pagination flex justify-center mt-6" aria-label="ページネーション">
    <div class="join">
      <%= prev_page_tag unless current_page.first? %>
      <% each_page do |page| -%>
        <% if page.left_outer? || page.right_outer? || page.inside_window? -%>
          <%= page_tag page %>
        <% elsif !page.was_truncated? -%>
          <%= gap_tag %>
        <% end -%>
      <% end -%>
      <%= next_page_tag unless current_page.last? %>
    </div>
  </nav>
<% end -%>
